# Copy this file to .env and fill in your values.
# Never commit .env — only .env.example is safe to commit.

# Neon (Postgres)
DATABASE_URL=

# Clerk
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# Anthropic
ANTHROPIC_API_KEY=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Cloudflare R2
CF_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Scraper Service (Railway/Fly.io — leave blank until deployed)
SCRAPER_SERVICE_URL=
SCRAPER_API_KEY=

# Expo mobile API base URL
EXPO_PUBLIC_API_URL=http://localhost:3000
