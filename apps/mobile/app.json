{
  "expo": {
    "name": "Vandu",
    "slug": "vandu",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "vandu",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1A2A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vandu.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D1A2A"
      },
      "package": "com.vandu.app",
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-share-intent",
        {
          "iosShareExtensionName": "Save to Vandu",
          "iosActivationRules": {
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsWebPageWithMaxCount": 1
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "dbeac7a7-0c03-42cb-8e4d-57d2340ae2eb"
      }
    }
  }
}
